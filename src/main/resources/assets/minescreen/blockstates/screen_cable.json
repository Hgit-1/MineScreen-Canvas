{
  "multipart": [
    {"apply": {"model": "minescreen:block/screen_cable_core"}},
    {"when": {"north": "true"}, "apply": {"model": "minescreen:block/screen_cable_arm_north"}},
    {"when": {"east": "true"}, "apply": {"model": "minescreen:block/screen_cable_arm_east"}},
    {"when": {"south": "true"}, "apply": {"model": "minescreen:block/screen_cable_arm_south"}},
    {"when": {"west": "true"}, "apply": {"model": "minescreen:block/screen_cable_arm_west"}},
    {"when": {"up": "true"}, "apply": {"model": "minescreen:block/screen_cable_arm_up"}},
    {"when": {"down": "true"}, "apply": {"model": "minescreen:block/screen_cable_arm_down"}}
  ]
}
